# =============================================================================
# Interior Design AI - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# AI Provider: "anthropic", "gemini", "together", "openai", or "local"
MODEL_PROVIDER=anthropic

# Model name (depends on provider)
# Anthropic: claude-sonnet-4-20250514, claude-haiku-4-20250514
# Gemini: gemini-2.0-flash
# Together: meta-llama/Llama-3.2-11B-Vision-Instruct-Turbo
# OpenAI: gpt-4o-mini
MODEL_NAME=claude-sonnet-4-20250514

# Fine-tuned models (set these after training on Together AI)
PINTEREST_MODEL=
STOCK_MODEL=

# --- API Keys (only need the one matching your MODEL_PROVIDER) ---

# Anthropic Claude (recommended - best vision quality)
# Get one at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Google Gemini (free tier available)
# Get one at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Together AI (for fine-tuning)
# Get one at: https://api.together.ai/settings/api-keys
TOGETHER_API_KEY=

# OpenAI (alternative)
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# --- Database ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/interior_design

# --- CORS ---
CORS_ORIGINS=["http://localhost:3000"]

# --- Debug ---
DEBUG=true
